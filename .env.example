# Copia este archivo a .env y reemplaza los valores de ejemplo

# Base de datos
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=proyectotaxis

# Mapbox (public token para el frontend)
MAPBOX_ACCESS_TOKEN=pk.tu_token_publico_mapbox

# SMTP
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_FROM_ADDRESS=correo@dominio.com
SMTP_FROM_NAME=Sistema automatico de Taxis
SMTP_USERNAME=correo@dominio.com
SMTP_PASSWORD=tu_password_smtp
SMTP_DEMO_TO=correo_destino_demo@dominio.com
